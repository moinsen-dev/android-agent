---
// Ghost in the Droid Landing Page — "Phantom Circuit" aesthetic
// Standalone page, does not use Starlight layout
---
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<title>Ghost in the Droid — Android Body for AI Agents</title>
	<meta name="description" content="Summon a ghost into your Android. Open-source framework for controlling real phones via ADB. No root required. No cloud dependency. Pure automation." />
	<meta property="og:title" content="Ghost in the Droid — Android Body for AI Agents" />
	<meta property="og:description" content="Open-source Python framework for automating Android devices. Build skills, manage phone farms, zero cloud dependency." />
	<meta property="og:image" content="/mascot/40-lineup-banner.png" />
	<meta property="og:type" content="website" />
	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:title" content="Ghost in the Droid" />
	<meta name="twitter:image" content="/mascot/40-lineup-banner.png" />
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
	<style>
		/* ═══════════ RESET & BASE ═══════════ */
		*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
		html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
		body {
			font-family: 'Outfit', sans-serif;
			background: #050505;
			color: #b0b0b0;
			line-height: 1.6;
			overflow-x: hidden;
		}
		a { color: inherit; text-decoration: none; }

		/* ═══════════ CSS VARS ═══════════ */
		:root {
			--accent: #00e5a0;
			--accent-dim: #00e5a018;
			--accent-mid: #00e5a040;
			--accent-glow: 0 0 80px #00e5a025, 0 0 200px #00e5a010;
			--surface: #0c0c0c;
			--surface-raised: #111111;
			--border: #1a1a1a;
			--border-hover: #2a2a2a;
			--text-primary: #e8e8e8;
			--text-secondary: #777;
			--max-w: 1140px;
			--radius: 12px;
		}

		/* ═══════════ NOISE TEXTURE ═══════════ */
		body::before {
			content: '';
			position: fixed;
			inset: 0;
			opacity: 0.03;
			background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
			background-size: 256px 256px;
			pointer-events: none;
			z-index: 9999;
		}

		/* ═══════════ NAV ═══════════ */
		nav {
			position: fixed;
			top: 0;
			left: 0;
			right: 0;
			z-index: 100;
			padding: 0 2rem;
			height: 64px;
			display: flex;
			align-items: center;
			justify-content: space-between;
			background: #050505cc;
			backdrop-filter: blur(20px) saturate(1.4);
			border-bottom: 1px solid var(--border);
			transition: border-color 0.3s;
		}
		.nav-logo {
			font-weight: 700;
			font-size: 1.2rem;
			color: var(--text-primary);
			letter-spacing: -0.5px;
			display: flex;
			align-items: center;
			gap: 0.5rem;
		}
		.nav-logo .nav-mascot {
			width: 32px;
			height: 32px;
			object-fit: contain;
			filter: drop-shadow(0 0 6px var(--accent));
			animation: float-mascot 3s ease-in-out infinite;
		}
		@keyframes float-mascot {
			0%, 100% { transform: translateY(0); }
			50% { transform: translateY(-2px); }
		}
		.nav-links {
			display: flex;
			gap: 2rem;
			align-items: center;
		}
		.nav-links a {
			font-size: 0.875rem;
			font-weight: 400;
			color: var(--text-secondary);
			transition: color 0.2s;
		}
		.nav-links a:hover { color: var(--text-primary); }
		.nav-cta {
			font-size: 0.8rem !important;
			font-weight: 500 !important;
			color: #050505 !important;
			background: var(--accent);
			padding: 0.4rem 1rem;
			border-radius: 6px;
			transition: opacity 0.2s, transform 0.2s;
		}
		.nav-cta:hover { opacity: 0.9; transform: translateY(-1px); }

		/* ═══════════ LAYOUT ═══════════ */
		.container { max-width: var(--max-w); margin: 0 auto; padding: 0 2rem; }
		section { padding: 6rem 0; }

		/* ═══════════ HERO ═══════════ */
		.hero {
			padding: 10rem 0 6rem;
			text-align: center;
			position: relative;
		}
		.hero::before {
			content: '';
			position: absolute;
			top: -200px;
			left: 50%;
			transform: translateX(-50%);
			width: 700px;
			height: 700px;
			background: radial-gradient(ellipse, var(--accent-dim) 0%, transparent 70%);
			pointer-events: none;
		}
		.hero-badge {
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			padding: 0.35rem 1rem;
			border: 1px solid var(--border);
			border-radius: 100px;
			font-size: 0.8rem;
			color: var(--text-secondary);
			margin-bottom: 2rem;
			background: var(--surface);
			animation: fade-up 0.6s ease-out both;
		}
		.hero-badge .tag {
			color: var(--accent);
			font-weight: 500;
		}
		.hero h1 {
			font-size: clamp(2.8rem, 6.5vw, 5rem);
			font-weight: 800;
			line-height: 1.05;
			letter-spacing: -2.5px;
			color: var(--text-primary);
			margin-bottom: 1.5rem;
			animation: fade-up 0.6s ease-out 0.1s both;
		}
		.hero h1 .gradient {
			background: linear-gradient(135deg, var(--accent) 0%, #00b4d8 50%, #7b68ee 100%);
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
			background-clip: text;
		}
		.hero-sub {
			font-size: 1.15rem;
			color: var(--text-secondary);
			max-width: 580px;
			margin: 0 auto 2.5rem;
			line-height: 1.7;
			font-weight: 300;
			animation: fade-up 0.6s ease-out 0.2s both;
		}
		.hero-actions {
			display: flex;
			gap: 1rem;
			justify-content: center;
			flex-wrap: wrap;
			animation: fade-up 0.6s ease-out 0.3s both;
		}
		.btn-primary {
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			padding: 0.75rem 1.75rem;
			background: var(--accent);
			color: #050505;
			font-weight: 600;
			font-size: 0.95rem;
			border-radius: 8px;
			border: none;
			cursor: pointer;
			transition: transform 0.2s, box-shadow 0.2s;
		}
		.btn-primary:hover {
			transform: translateY(-2px);
			box-shadow: 0 8px 30px #00e5a030;
		}
		.btn-outline {
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			padding: 0.75rem 1.75rem;
			background: transparent;
			color: var(--text-primary);
			font-weight: 500;
			font-size: 0.95rem;
			border-radius: 8px;
			border: 1px solid var(--border);
			cursor: pointer;
			transition: border-color 0.2s, background 0.2s;
		}
		.btn-outline:hover {
			border-color: var(--border-hover);
			background: var(--surface);
		}

		/* ═══════════ TERMINAL ═══════════ */
		.terminal-section { padding: 2rem 0 6rem; }
		.terminal {
			background: var(--surface);
			border: 1px solid var(--border);
			border-radius: var(--radius);
			overflow: hidden;
			max-width: 700px;
			margin: 0 auto;
			animation: fade-up 0.6s ease-out 0.4s both;
			box-shadow: 0 20px 60px rgba(0,0,0,0.4);
		}
		.terminal-header {
			display: flex;
			align-items: center;
			gap: 6px;
			padding: 0.75rem 1rem;
			background: var(--surface-raised);
			border-bottom: 1px solid var(--border);
		}
		.terminal-dot {
			width: 10px;
			height: 10px;
			border-radius: 50%;
		}
		.terminal-dot.r { background: #ff5f57; }
		.terminal-dot.y { background: #febc2e; }
		.terminal-dot.g { background: #28c840; }
		.terminal-title {
			font-family: 'JetBrains Mono', monospace;
			font-size: 0.7rem;
			color: var(--text-secondary);
			margin-left: 0.5rem;
		}
		.terminal-body {
			padding: 1.25rem 1.5rem;
			font-family: 'JetBrains Mono', monospace;
			font-size: 0.82rem;
			line-height: 1.8;
			overflow-x: auto;
		}
		.t-kw { color: #c792ea; }
		.t-fn { color: #82aaff; }
		.t-str { color: #c3e88d; }
		.t-cm { color: #546e7a; }
		.t-num { color: #f78c6c; }
		.t-op { color: #89ddff; }
		.t-var { color: #e8e8e8; }

		/* ═══════════ DEMO VIDEO TOGGLE ═══════════ */
		.demo-section { padding: 2rem 0 6rem; }
		.demo-header {
			display: flex;
			justify-content: space-between;
			align-items: flex-end;
			margin-bottom: 2rem;
			flex-wrap: wrap;
			gap: 1rem;
		}
		.demo-header h2 {
			font-size: clamp(1.6rem, 3vw, 2.2rem);
			font-weight: 700;
			color: var(--text-primary);
			letter-spacing: -1px;
		}
		.demo-header p {
			color: var(--text-secondary);
			font-size: 0.95rem;
			font-weight: 300;
			margin-top: 0.35rem;
		}
		.demo-tabs {
			display: flex;
			gap: 0;
			border: 1px solid var(--border);
			border-radius: 8px;
			overflow: hidden;
			background: var(--surface);
		}
		.demo-tab {
			padding: 0.55rem 1.25rem;
			font-size: 0.82rem;
			font-weight: 500;
			color: var(--text-secondary);
			cursor: pointer;
			transition: all 0.25s;
			border: none;
			background: transparent;
			font-family: 'Outfit', sans-serif;
			border-right: 1px solid var(--border);
			white-space: nowrap;
		}
		.demo-tab:last-child { border-right: none; }
		.demo-tab:hover { color: var(--text-primary); background: var(--surface-raised); }
		.demo-tab.active {
			color: #050505;
			background: var(--accent);
			font-weight: 600;
		}
		.demo-player {
			position: relative;
			border-radius: var(--radius);
			overflow: hidden;
			border: 1px solid var(--border);
			background: #000;
			aspect-ratio: 16 / 9;
			max-width: 900px;
			margin: 0 auto;
			box-shadow: 0 20px 60px rgba(0,0,0,0.5);
		}
		.demo-player video {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			object-fit: cover;
			opacity: 0;
			transition: opacity 0.4s ease;
		}
		.demo-player video.active { opacity: 1; }
		.demo-subtitle {
			text-align: center;
			margin-top: 1rem;
			font-size: 0.85rem;
			color: var(--text-secondary);
			font-weight: 300;
		}
		@media (max-width: 768px) {
			.demo-header { flex-direction: column; align-items: flex-start; }
		}

		/* ═══════════ FEATURES — Alternating rows with ghost images ═══════════ */
		.features-section { padding-top: 4rem; }
		.section-label {
			font-size: 0.75rem;
			font-weight: 500;
			text-transform: uppercase;
			letter-spacing: 2px;
			color: var(--accent);
			margin-bottom: 1rem;
		}
		.section-title {
			font-size: clamp(1.8rem, 3.5vw, 2.5rem);
			font-weight: 700;
			color: var(--text-primary);
			letter-spacing: -1px;
			margin-bottom: 1rem;
		}
		.section-sub {
			color: var(--text-secondary);
			font-size: 1.05rem;
			max-width: 550px;
			font-weight: 300;
			margin-bottom: 3.5rem;
		}
		.feature-row {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 4rem;
			align-items: center;
			padding: 4rem 0;
			border-bottom: 1px solid var(--border);
		}
		.feature-row:last-child { border-bottom: none; }
		.feature-row.reverse .feature-img { order: 2; }
		.feature-row.reverse .feature-text { order: 1; }
		.feature-img {
			display: flex;
			align-items: center;
			justify-content: center;
		}
		.feature-img img {
			max-width: 280px;
			max-height: 280px;
			width: 100%;
			height: auto;
			object-fit: contain;
			filter: drop-shadow(0 0 40px rgba(0, 229, 160, 0.1));
			transition: transform 0.3s ease;
		}
		.feature-row:hover .feature-img img {
			transform: scale(1.04);
		}
		.feature-text h3 {
			font-size: 1.4rem;
			font-weight: 700;
			color: var(--text-primary);
			margin-bottom: 0.75rem;
			letter-spacing: -0.5px;
		}
		.feature-text p {
			font-size: 0.95rem;
			color: var(--text-secondary);
			line-height: 1.7;
			max-width: 480px;
		}
		.feature-tag {
			display: inline-block;
			font-size: 0.7rem;
			font-weight: 500;
			text-transform: uppercase;
			letter-spacing: 1.5px;
			color: var(--accent);
			background: var(--accent-dim);
			padding: 0.25rem 0.7rem;
			border-radius: 4px;
			margin-bottom: 0.75rem;
		}

		/* ═══════════ HERO WITH GHOST ═══════════ */
		.hero-split {
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 3rem;
		}
		.hero-content { text-align: left; flex: 1; max-width: 560px; }
		.hero-ghost {
			flex-shrink: 0;
			width: 280px;
		}
		.hero-ghost img {
			width: 100%;
			height: auto;
			filter: drop-shadow(0 0 60px rgba(0, 229, 160, 0.15));
		}
		@media (max-width: 768px) {
			.hero-split { flex-direction: column; text-align: center; }
			.hero-content { text-align: center; }
			.hero-ghost { width: 200px; order: -1; }
		}

		/* ═══════════ HOW IT WORKS ═══════════ */
		.steps-grid {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 2rem;
			margin-top: 3rem;
		}
		.step {
			position: relative;
			padding: 2rem;
			border: 1px solid var(--border);
			border-radius: var(--radius);
			background: var(--surface);
			transition: border-color 0.3s;
		}
		.step:hover { border-color: var(--accent-mid); }
		.step-num {
			font-family: 'JetBrains Mono', monospace;
			font-size: 0.7rem;
			font-weight: 500;
			color: var(--accent);
			background: var(--accent-dim);
			padding: 0.25rem 0.6rem;
			border-radius: 4px;
			display: inline-block;
			margin-bottom: 1rem;
		}
		.step h3 {
			font-size: 1.1rem;
			font-weight: 600;
			color: var(--text-primary);
			margin-bottom: 0.5rem;
		}
		.step p {
			font-size: 0.875rem;
			color: var(--text-secondary);
			line-height: 1.6;
		}
		.step-connector {
			display: none;
		}

		/* ═══════════ STATS ═══════════ */
		.stats-section {
			padding: 4rem 0;
			border-top: 1px solid var(--border);
			border-bottom: 1px solid var(--border);
		}
		.stats-grid {
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			gap: 2rem;
			text-align: center;
		}
		.stat-value {
			font-size: clamp(1.8rem, 3vw, 2.5rem);
			font-weight: 700;
			color: var(--text-primary);
			letter-spacing: -1px;
		}
		.stat-label {
			font-size: 0.8rem;
			color: var(--text-secondary);
			margin-top: 0.25rem;
		}

		/* ═══════════ CTA ═══════════ */
		.cta-section {
			text-align: center;
			padding: 8rem 0;
			position: relative;
		}
		.cta-section::before {
			content: '';
			position: absolute;
			bottom: 0;
			left: 50%;
			transform: translateX(-50%);
			width: 500px;
			height: 500px;
			background: radial-gradient(ellipse, var(--accent-dim) 0%, transparent 70%);
			pointer-events: none;
		}
		.cta-section h2 {
			font-size: clamp(2rem, 4vw, 3rem);
			font-weight: 700;
			color: var(--text-primary);
			letter-spacing: -1.5px;
			margin-bottom: 1rem;
		}
		.cta-section p {
			color: var(--text-secondary);
			font-size: 1.05rem;
			margin-bottom: 2.5rem;
			font-weight: 300;
		}

		/* ═══════════ FOOTER ═══════════ */
		footer {
			border-top: 1px solid var(--border);
			padding: 3rem 0;
		}
		.footer-inner {
			display: flex;
			justify-content: space-between;
			align-items: center;
			flex-wrap: wrap;
			gap: 1rem;
		}
		.footer-left {
			font-size: 0.8rem;
			color: var(--text-secondary);
		}
		.footer-links {
			display: flex;
			gap: 1.5rem;
		}
		.footer-links a {
			font-size: 0.8rem;
			color: var(--text-secondary);
			transition: color 0.2s;
		}
		.footer-links a:hover { color: var(--text-primary); }

		/* ═══════════ ANIMATIONS ═══════════ */
		@keyframes fade-up {
			from { opacity: 0; transform: translateY(20px); }
			to { opacity: 1; transform: translateY(0); }
		}

		/* ═══════════ RESPONSIVE ═══════════ */
		@media (max-width: 768px) {
			.feature-row { grid-template-columns: 1fr; gap: 2rem; text-align: center; }
			.feature-row.reverse .feature-img { order: -1; }
			.feature-row.reverse .feature-text { order: 2; }
			.feature-img img { max-width: 200px; }
			.steps-grid { grid-template-columns: 1fr; }
			.stats-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
			.hero { padding: 8rem 0 4rem; }
			.nav-links a:not(.nav-cta) { display: none; }
			section { padding: 4rem 0; }
		}
		@media (max-width: 480px) {
			.stats-grid { grid-template-columns: 1fr; }
			.hero h1 { letter-spacing: -1.5px; }
		}
	</style>
	<!-- Vercel Web Analytics (Starlight head-injection doesn't reach this standalone page) -->
	<script defer src="/_vercel/insights/script.js"></script>
</head>
<body>
	<!-- NAV -->
	<nav>
		<a href="/" class="nav-logo">
			<img src="/mascot/43-wave.png" alt="Ghost mascot" class="nav-mascot" />
			Ghost in the Droid
		</a>
		<div class="nav-links">
			<a href="/getting-started/introduction/">Docs</a>
			<a href="/skills/">Skill Hub</a>
			<a href="http://localhost:6175" target="_blank">Dashboard</a>
			<a href="https://github.com/ghost-in-the-droid/android-agent">GitHub</a>
			<a href="/getting-started/installation/" class="nav-cta">Get Started</a>
		</div>
	</nav>

	<!-- ASCII SPHERE -->
	<canvas id="ascii-sphere" style="position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none;opacity:0.35"></canvas>

	<!-- HERO -->
	<section class="hero" style="position:relative;z-index:1">
		<div class="container">
			<div class="hero-badge">
				<span class="tag">Open Source</span>
				<span>MIT Licensed — free forever</span>
			</div>
			<div class="hero-split">
				<div class="hero-content">
					<h1>
						Summon a Ghost<br/>Into Your <span class="gradient">Android</span>
					</h1>
					<p class="hero-sub">
						It sees the screen. It taps the buttons. It never sleeps.
						Open-source Python framework for controlling real phones via ADB.
						No root required. No cloud dependency. Pure automation.
					</p>
					<div class="hero-actions">
						<a href="/getting-started/installation/" class="btn-primary">
							Get Started
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
