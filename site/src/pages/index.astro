	<script>
	(function() {
		const canvas = document.getElementById('ascii-sphere');
		if (!canvas) return;
		const ctx = canvas.getContext('2d');
		const chars = '.:-=+*#%@'.split('');
		let mx = 0.5, my = 0.5, time = 0;
		let W, H, cols, rows, cellW, cellH;

		function resize() {
			const dpr = window.devicePixelRatio || 1;
			W = window.innerWidth;
			H = window.innerHeight;
			canvas.width = W * dpr;
			canvas.height = H * dpr;
			ctx.scale(dpr, dpr);
			cellW = 10;
			cellH = 16;
			cols = Math.floor(W / cellW);
			rows = Math.floor(H / cellH);
		}
		resize();
		window.addEventListener('resize', resize);

		document.addEventListener('mousemove', function(e) {
			mx = e.clientX / W;
			my = e.clientY / H;
		});

		// Make canvas interactive for mouse tracking
		canvas.style.pointerEvents = 'auto';
		canvas.addEventListener('mousemove', function(e) {
			mx = e.clientX / W;
			my = e.clientY / H;
		});

		function render() {
			time += 0.008;
			ctx.clearRect(0, 0, W, H);
			ctx.font = '12px "JetBrains Mono", monospace';
			ctx.textBaseline = 'top';

			// Sphere params
			var cx = W * 0.5;
			var cy = H * 0.38;
			var radius = Math.min(W, H) * 0.28;
			var rotX = (my - 0.5) * 2.5 + time * 0.3;
			var rotY = (mx - 0.5) * 2.5 + time * 0.5;

			// Mouse distortion point
			var dmx = mx * W;
			var dmy = my * H;

			var points = 1200;
			for (var i = 0; i < points; i++) {
				// Fibonacci sphere distribution
				var phi = Math.acos(1 - 2 * (i + 0.5) / points);
				var theta = Math.PI * (1 + Math.sqrt(5)) * i;

				var x = Math.sin(phi) * Math.cos(theta);
				var y = Math.sin(phi) * Math.sin(theta);
				var z = Math.cos(phi);

				// Rotate Y
				var x2 = x * Math.cos(rotY) - z * Math.sin(rotY);
				var z2 = x * Math.sin(rotY) + z * Math.cos(rotY);

				// Rotate X
				var y2 = y * Math.cos(rotX) - z2 * Math.sin(rotX);
				var z3 = y * Math.sin(rotX) + z2 * Math.cos(rotX);

				// Project
				var scale = 1 / (1 + z3 * 0.4);
				var px = cx + x2 * radius * scale;
				var py = cy + y2 * radius * scale;

				// Mouse distortion
				var ddx = px - dmx;
				var ddy = py - dmy;
				var dist = Math.sqrt(ddx * ddx + ddy * ddy);
				var distortion = Math.max(0, 1 - dist / 200);
				if (distortion > 0) {
					var push = distortion * distortion * 60;
					px += (ddx / (dist || 1)) * push;
					py += (ddy / (dist || 1)) * push;
				}

				// Depth-based brightness
				var brightness = (z3 + 1) * 0.5;
				var charIdx = Math.floor(brightness * (chars.length - 1));
				var alpha = 0.15 + brightness * 0.85;

				// Green tint matching accent
				var g = Math.floor(160 + brightness * 69);
				ctx.fillStyle = 'rgba(0,' + g + ',' + Math.floor(100 + brightness * 60) + ',' + alpha * (0.5 + distortion * 0.5) + ')';
				ctx.fillText(chars[charIdx], px, py);
			}

			requestAnimationFrame(render);
		}
		render();
	})();
	</script>
	<script>
	(function() {
		const tabs = document.querySelectorAll('.demo-tab');
		const videos = document.querySelectorAll('.demo-player video');
		const sub = document.getElementById('demo-sub');
		const subs = {
			reddit: 'The ghost searches Reddit, finds a post, and leaves a comment.',
			amazon: 'The ghost searches for a product on Amazon, browses results and reviews.',
			booking: 'The ghost searches for a hotel on Booking, picks dates and filters results.',
		};
		tabs.forEach(function(tab) {
			tab.addEventListener('click', function() {
				var target = tab.dataset.video;
				tabs.forEach(function(t) { t.classList.remove('active'); });
				tab.classList.add('active');
				videos.forEach(function(v) {
					if (v.src.includes(target)) {
						v.classList.add('active');
						v.play();
					} else {
						v.classList.remove('active');
						v.pause();
					}
				});
				sub.textContent = subs[target] || '';
			});
		});
	})();
	</script>
