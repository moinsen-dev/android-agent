# Copy this to .env and fill in your values

# Device (ADB serial — leave empty to auto-detect first connected device)
DEFAULT_DEVICE=

# AI / LLM (at least one required for Agent Chat and Skill Creator)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=

# Optional: override the DeepSeek API endpoint (defaults to https://api.deepseek.com/v1)
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
